void loop() {

  unsigned long acum = millis();
 
  bool receptorRidicat = (digitalRead(PIN_BUTON) == HIGH); // HIGH = declanșare

  int starePinVocal = digitalRead(PIN_VOCAL_DEDICAT);
 
  // --- DEBUG: afișează starea pinilor la fiecare secundă ---

  static unsigned long ultimulDebug = 0;

  if (acum - ultimulDebug > 1000) {

    ultimulDebug = acum;

    Serial.print("[DEBUG] PIN_BUTON=");

    Serial.print(digitalRead(PIN_BUTON));

    Serial.print(" (receptorRidicat=");

    Serial.print(receptorRidicat);

    Serial.print(") | PIN_VOCAL_DEDICAT=");

    Serial.println(starePinVocal);

  }
 
  if (serialGSM.available()) {

    Serial.write(serialGSM.read());

  }
 
  // ==========================================

  // TRIGGER 1: Furca Mecanică

  // ==========================================

  if (receptorRidicat && (acum - timpUltimaApasare > 4000)) {

    timpUltimaApasare = acum;
 
    Serial.println("[TRIGGER] >>> FURCA MECANICA a declansat alerta! PIN_BUTON era HIGH.");

    sursaAlerta = "\n\nFurca mecanică\n\n";
 
    digitalWrite(PIN_BUZZER, HIGH);

    delay(3000);

    digitalWrite(PIN_BUZZER, LOW);
 
    afisare("SOS", "ACTIVAT!", ST77XX_CYAN);

    trimiteAlerta();

  }
 
  // ==========================================

  // TRIGGER 2: Comanda Vocală

  // ==========================================

  if (digitalRead(PIN_VOCAL_DEDICAT) == HIGH) {

    delay(50);
 
    if (digitalRead(PIN_VOCAL_DEDICAT) == HIGH && (acum - timpUltimaVocal > 5000)) {

      timpUltimaVocal = acum;
 
      Serial.println("[TRIGGER] >>> COMANDA VOCALA a declansat alerta! PIN_VOCAL_DEDICAT era HIGH.");

      sursaAlerta = "\n\nComanda vocala\n\n";
 
      digitalWrite(PIN_BUZZER, HIGH);

      delay(3000);

      digitalWrite(PIN_BUZZER, LOW);
 
      afisare("SOS", "ACTIVAT!", ST77XX_RED);

      trimiteAlerta();

    }

  }

}
 
