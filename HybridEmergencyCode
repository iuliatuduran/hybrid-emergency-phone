bool apelActiv() {
  String r = trimiteAT("AT+CLCC", 1000);
  if (r.indexOf("+CLCC:") == -1) return false; // fara apel raportat = terminat
  int idx = r.indexOf("+CLCC:") + 6;
  String part = r.substring(idx);
  part.trim();
  int c1 = part.indexOf(',');
  int c2 = part.indexOf(',', c1 + 1);
  int c3 = part.indexOf(',', c2 + 1);
  if (c1 == -1 || c2 == -1 || c3 == -1) return false;
  String stat = part.substring(c2 + 1, c3);
  stat.trim();
  return (stat == "0"); // 0 = activ (raspuns)
}

void faApel() {
  afisare("RETEA", "Verific GSM...", ST77XX_YELLOW);
  asteaptaRetea(20);

  afisare("APEL", "Suna...", ST77XX_RED);
  trimiteAT("ATH", 1000);
  delay(500);
  trimiteAT("ATX4", 500);
  delay(300);

  for (int i = 1; i <= 2; i++) {
    for (int tasta = 0; tasta < 7; tasta++) {
      digitalWrite(PIN_BUZZER, HIGH);
      delay(70);
      digitalWrite(PIN_BUZZER, LOW);
      delay(90);
    }
    delay(300);

    String r = trimiteAT("ATD" + numarUrgenta + ";", 5000);
    Serial.println("Apel " + String(i) + ": " + r);

    if (r.indexOf("NO CARRIER") == -1 && r.indexOf("ERROR") == -1 && r.indexOf("BUSY") == -1) {
      afisare("APEL", "In curs...", ST77XX_RED);

      unsigned long startApel = millis();
      unsigned long ultimaVerifCLCC = 0;
      bool apelIntrerupt = false;
      bool apelRaspuns = false;

      while (millis() - startApel < 25000) {

        //Verifica INTAI orice mesaj sosit direct pe serial
        String feedback = "";
        if (serialGSM.available()) {
          while (serialGSM.available()) feedback += (char)serialGSM.read();
          Serial.println("Feedback primit în timpul apelului: " + feedback);
        }
        if (feedback.indexOf("NO CARRIER") != -1 || feedback.indexOf("BUSY") != -1 || feedback.indexOf("NO ANSWER") != -1) {
          apelIntrerupt = true;
          break;
        }

        //Verifica starea prin CLCC (o data la ~1.5s), totul inline
        if (millis() - ultimaVerifCLCC > 1500) {
          ultimaVerifCLCC = millis();

          String clcc = trimiteAT("AT+CLCC", 1500);

          if (clcc.indexOf("NO CARRIER") != -1 || clcc.indexOf("BUSY") != -1 || clcc.indexOf("NO ANSWER") != -1) {
            apelIntrerupt = true;
            digitalWrite(PIN_BUZZER, LOW);
            Serial.println("Apel TERMINAT (NO CARRIER in CLCC) - opresc buzzerul");
            break;
          }

          if (clcc.indexOf("+CLCC:") != -1) {
            //Exista apel raportat - verificam starea
            int idx = clcc.indexOf("+CLCC:") + 6;
            String part = clcc.substring(idx);
            part.trim();
            int c1 = part.indexOf(',');
            int c2 = part.indexOf(',', c1 + 1);
            int c3 = part.indexOf(',', c2 + 1);
            if (c1 != -1 && c2 != -1 && c3 != -1) {
              String stat = part.substring(c2 + 1, c3);
              stat.trim();
              if (stat == "0" && !apelRaspuns) {
                apelRaspuns = true;
                digitalWrite(PIN_BUZZER, LOW);
                Serial.println("Apel RASPUNS - opresc buzzerul");
              }
            }
          } else if (clcc.indexOf("OK") != -1) {
            //Raspuns OK dar fara +CLCC: -> nu mai exista apel activ -> respins/inchis
            apelIntrerupt = true;
            digitalWrite(PIN_BUZZER, LOW);
            Serial.println("Apel TERMINAT (fara +CLCC in raspuns) - opresc buzzerul");
            break;
          }
          //Daca raspunsul e complet gol, nu facem nimic - incercam din nou la urmatoarea verificare
        }

        if (!apelRaspuns) {
          digitalWrite(PIN_BUZZER, HIGH); delay(300); digitalWrite(PIN_BUZZER, LOW); delay(150);
          digitalWrite(PIN_BUZZER, HIGH); delay(300); digitalWrite(PIN_BUZZER, LOW);

          for (int p = 0; p < 25; p++) {
            if (millis() - startApel >= 25000) break;

            String feedbackPauza = "";
            if (serialGSM.available()) {
              while (serialGSM.available()) feedbackPauza += (char)serialGSM.read();
            }
            if (feedbackPauza.indexOf("NO CARRIER") != -1 || feedbackPauza.indexOf("BUSY") != -1) {
              apelIntrerupt = true;
              break;
            }
            delay(100);
          }
          if (apelIntrerupt) break;
        } else {
          delay(200);
        }
      }

      digitalWrite(PIN_BUZZER, LOW);
      trimiteAT("ATH", 1000);
      return;
    }

    digitalWrite(PIN_BUZZER, LOW);
    afisare("APEL", "Retry " + String(i) + "...", ST77XX_YELLOW);
    delay(3000);
  }

  afisare("APEL", "Esuat!", ST77XX_RED);
  delay(1000);
}

void trimiteAlerta() {
  unsigned long t0 = millis(); // START total
  Serial.println("T0 - Alerta declansata: " + String(t0) + "ms");

  afisare("SOS", "ACTIVAT!", ST77XX_RED);
  delay(500);

  //LOCALIZARE GSM
  unsigned long tGSM_start = millis();
  Serial.println("T1 - Inceput localizare GSM: " + String(tGSM_start - t0) + "ms de la start");

  String mcc="", mnc="", lac="", cid="", semnal="";
  bool gsmOK = citesteGSM(mcc, mnc, lac, cid, semnal);

  unsigned long tGSM_end = millis();
  Serial.println("T2 - Sfarsit localizare GSM: " + String(tGSM_end - t0) + "ms de la start");
  Serial.println("Durata localizare GSM: " + String(tGSM_end - tGSM_start) + "ms");

  //GOOGLE API
  unsigned long tGoogle_start = millis();
  Serial.println("T3 - Inceput Google API: " + String(tGoogle_start - t0) + "ms de la start");

  String lat="", lon="", prec="";
  bool coordOK = false;
  if (gsmOK) {
    coordOK = geolocalizeaza(mcc, mnc, lac, cid, lat, lon, prec);
  }

  unsigned long tGoogle_end = millis();
  Serial.println("T4 - Sfarsit Google API: " + String(tGoogle_end - t0) + "ms de la start");
  Serial.println("Durata Google API: " + String(tGoogle_end - tGoogle_start) + "ms");

  String timestamp = getTimestamp();
  String mesaj = " *ALERTA SOS*:" + sursaAlerta;
  mesaj += "*Data si Ora:* " + timestamp + "\n\n";

  if (coordOK) {
    mesaj += " *LOCATIE:*\n";
    mesaj += "• Lat: `" + lat + "`\n";
    mesaj += "• Lon: `" + lon + "`\n";
    mesaj += "• Precizie: ~" + prec + " metri\n\n";
    mesaj += " *GOOGLE MAPS:*\n";
    mesaj += "https://www.google.com/maps?q=" + lat + "," + lon + "\n\n";
  } else {
    mesaj += " _Locatie indisponibila_\n\n";
  }

  mesaj += "*DATE TURN GSM:*\n";
  if (gsmOK) {
    mesaj += "• MCC: `" + mcc + "` MNC: `" + mnc + "`\n";
    mesaj += "• LAC: `" + lac + "`\n";
    mesaj += "• Cell ID: `" + cid + "`\n";
    mesaj += "• Semnal: `" + semnal + "dBm`";
  } else {
    mesaj += "• Date turn indisponibile";
  }

  //TELEGRAM
