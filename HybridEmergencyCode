  Serial.println("Durata apel: " + String(tApel_end - tApel_start) + "ms");

  //TOTAL
  unsigned long tTotal = millis() - t0;
  Serial.println("TOTAL end-to-end: " + String(tTotal) + "ms (" + String(tTotal/1000) + " secunde)");
  

  buzzerConfirmare();

  tft.fillScreen(ST77XX_BLACK);
  tft.setCursor(10, 20); tft.setTextColor(ST77XX_GREEN); tft.setTextSize(2); tft.println("SISTEM ACTIV");
  tft.drawFastHLine(0, 50, 240, ST77XX_GREEN);
  tft.setCursor(10, 65); tft.setTextColor(ST77XX_CYAN); tft.println("WiFi: OK");
  tft.setCursor(10, 100); tft.setTextColor(ST77XX_CYAN); tft.println(infoRetea);
  tft.drawFastHLine(0, 175, 240, ST77XX_YELLOW);
  tft.setTextColor(ST77XX_YELLOW);
  tft.setCursor(10, 190); tft.println("Ridica receptorul");
  tft.setCursor(10, 220); tft.println("SAU spune vocal:");
  tft.setCursor(10, 250); tft.setTextColor(ST77XX_CYAN); tft.println("\"AJUTOR!\"");
  tft.fillCircle(220, 300, 8, 0xF81F);
  //tft.fillCircle(220, 300, 8, ST77XX_GREEN);
