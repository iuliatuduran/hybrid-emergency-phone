String trimiteAT(String comanda, int timeout_ms = 3000) {
  while (serialGSM.available()) serialGSM.read();
  serialGSM.println(comanda);
  String resp = "";
  unsigned long t = millis();
  while (!serialGSM.available() && millis() < t + 2000);
  unsigned long lastChar = millis();
  while (millis() < t + timeout_ms) {
    if (serialGSM.available()) {
      resp += (char)serialGSM.read();
      lastChar = millis();
    }
    if (resp.length() > 0 && millis() - lastChar > 500) break;
  }
  Serial.println(">>> " + comanda);
  Serial.println("<<< " + resp);
  Serial.println("---");
  return resp;
}


bool asteaptaRetea(int secMax = 30) {
  for (int i = 0; i < secMax; i++) {
    String r = trimiteAT("AT+CREG?", 2000);
    if (r.indexOf(",1") != -1 || r.indexOf(",5") != -1) {
      Serial.println("Retea OK!");
      return true;
    }
    afisare("RETEA", "Astept " + String(i+1) + "/" + String(secMax), ST77XX_YELLOW);
    delay(1000);
  }
  return false;
}


String hexToDec(String h) {
  h.trim();
  if (h.length() == 0) return "0";
  return String(strtoul(h.c_str(), NULL, 16));
}


bool citesteGSM(String &mcc, String &mnc, String &lac, String &cid, String &semnal) {

  //PASUL 1: Așteapta rețea
  afisare("GSM", "Astept retea...", ST77XX_CYAN);
  if (!asteaptaRetea(30)) {
    Serial.println("Retea indisponibila!");
    return false;
  }
  delay(2000); 
  //--- Detectare operator (rulează mereu) ---
  String cops = trimiteAT("AT+COPS?", 3000);
  Serial.println("COPS: " + cops);
  String numeOperator = "Necunoscut";
  String tehnologie = "";
  int qi1 = cops.indexOf('"');
  int qi2 = cops.indexOf('"', qi1 + 1);
  if (qi1 != -1 && qi2 != -1) numeOperator = cops.substring(qi1 + 1, qi2);
 String numeOperatorUpper = numeOperator;
numeOperatorUpper.toUpperCase();
if (numeOperatorUpper.indexOf("CONNEX") != -1 || numeOperatorUpper.indexOf("VODAFONE") != -1) {
  numeOperator = "Vodafone";
}
  int lastComma = cops.lastIndexOf(',');
  if (lastComma != -1) {
    int act = cops.substring(lastComma + 1).toInt();
    switch (act) {
      case 0: case 1: case 3: tehnologie = "2G"; break;
      case 2: case 4: case 5: case 6: tehnologie = "3G"; break;
      case 7: tehnologie = "4G"; break;
      default: tehnologie = ""; break;
    }
  }
  infoRetea = "GSM: " + numeOperator + (tehnologie != "" ? " " + tehnologie : "");
  Serial.println("Operator detectat: " + infoRetea);
  if (numeOperator.indexOf("Digi") != -1 || numeOperator.indexOf("RCS") != -1) { mcc="226"; mnc="5"; }
  else if (numeOperator.indexOf("Vodafone") != -1) { mcc="226"; mnc="1"; }
  else if (numeOperator.indexOf("Orange") != -1)   { mcc="226"; mnc="10"; }
  else if (numeOperator.indexOf("Telekom") != -1)  { mcc="226"; mnc="3"; }
  else { mcc="226"; mnc="5"; }
  //PASUL 2: Încearcă AT+CCED 
  afisare("GSM", "Citesc turn...", ST77XX_CYAN);
  String resp = trimiteAT("AT+CCED=0,1", 3000);
  Serial.println("CCED RAW: [" + resp + "]");
  //Format CCED: +CCED: MCC,MNC,LAC,CID,BSIC,ARC,TA,DBM,...)
  if (resp.indexOf("+CCED:") != -1) {
    int idx = resp.indexOf("+CCED:") + 6;
    String date = resp.substring(idx);
    date.trim();
    Serial.println("CCED date: [" + date + "]");
    String c[10];
    int ci = 0, start = 0;
    for (int i = 0; i <= (int)date.length() && ci < 10; i++) {
      if (i == (int)date.length() || date[i] == ',') {
        c[ci++] = date.substring(start, i);
        start = i + 1;
      }
    }
    if (ci >= 4) {
      mcc    = c[0]; mcc.trim();
      mnc    = c[1]; mnc.trim();
      lac    = hexToDec(c[2]);
      cid    = hexToDec(c[3]);
      semnal = (ci >= 8) ? c[7] : "?";
      semnal.trim();

      Serial.println("CCED -> MCC=" + mcc + " MNC=" + mnc + 
                     " LAC=" + lac + " CID=" + cid);

      //Verifica dacă sunt date reale, nu zerouri
      if (lac != "0" && cid != "0" && mcc.length() >= 3) {
        return true;
      }
      Serial.println("CCED a returnat zerouri, incerc CENG...");
    }  
  }
  //PASUL 3: AT+CENG
  Serial.println("Incerc AT+CENG...");
  trimiteAT("AT+CENG=1,1", 1000);
  delay(1000); // Asteapta sa se populeze
  resp = trimiteAT("AT+CENG?", 3000);
  Serial.println("CENG RAW: [" + resp + "]");
  //Format: +CENG: 0,"arfcn,rxl,rxq,mcc,mnc,bsic,cellid,rla,txp,lac,TA"
  int searchFrom = 0;
  while (true) {
    int p1 = resp.indexOf('"', searchFrom);
    if (p1 == -1) break;
    int p2 = resp.indexOf('"', p1 + 1);
    if (p2 == -1) break;

    String date = resp.substring(p1 + 1, p2);
    searchFrom = p2 + 1;

    String c[11];
    int ci = 0, start = 0;
    for (int i = 0; i <= (int)date.length() && ci < 11; i++) {
      if (i == (int)date.length() || date[i] == ',') {
        c[ci++] = date.substring(start, i);
        start = i + 1;
      }
    }

    if (ci < 10) continue;

    String tmpMCC = c[3]; tmpMCC.trim();
    String tmpMNC = c[4]; tmpMNC.trim();
    String tmpCID = hexToDec(c[6]);
    String tmpLAC = hexToDec(c[9]);

    Serial.println("CENG linie: MCC=" + tmpMCC + " MNC=" + tmpMNC + 
                   " LAC=" + tmpLAC + " CID=" + tmpCID);

    //Accepta doar daca nu sunt zerouri
    if (tmpLAC != "0" && tmpCID != "0" && 
        tmpMCC.length() >= 3 && tmpMCC != "000") {
      mcc    = tmpMCC;
      mnc    = tmpMNC;
      lac    = tmpLAC;
      cid    = tmpCID;
      semnal = c[1]; semnal.trim();
      Serial.println("CENG OK: MCC=" + mcc + " MNC=" + mnc + 
                     " LAC=" + lac + " CID=" + cid);
      return true;
    }
  }

  //PASUL 4: Ultima sansa - AT+CSQ pentru semnal + AT+CREG pentru info
  Serial.println("CENG tot zerouri! Incerc CREG extins...");
  resp = trimiteAT("AT+CREG=2", 1000); 
  delay(500);
  resp = trimiteAT("AT+CREG?", 3000);
  Serial.println("CREG ext: [" + resp + "]");

  // Format extins: +CREG: 2,1,"LAC_HEX","CID_HEX"
  if (resp.indexOf("+CREG:") != -1) {
    int idx = resp.indexOf("+CREG:") + 6;
    String part = resp.substring(idx);
    part.trim();

    // Caută ghilimelele pentru LAC si CID
    int q1 = part.indexOf('"');
    int q2 = part.indexOf('"', q1 + 1);
    int q3 = part.indexOf('"', q2 + 1);
    int q4 = part.indexOf('"', q3 + 1);

    if (q1 != -1 && q2 != -1 && q3 != -1 && q4 != -1) {
      String lacHex = part.substring(q1 + 1, q2);
      String cidHex = part.substring(q3 + 1, q4);
      lac = hexToDec(lacHex);
      cid = hexToDec(cidHex);

      Serial.println("CREG -> LAC=" + lac + " CID=" + cid);


      String cops = trimiteAT("AT+COPS?", 3000);
      Serial.println("COPS: " + cops);
      String csq = trimiteAT("AT+CSQ", 2000);
      semnal = "?";
      if (csq.indexOf("+CSQ:") != -1) {
        int si = csq.indexOf("+CSQ:") + 5;
        semnal = csq.substring(si, csq.indexOf(",", si));
        semnal.trim();
      }

      if (lac != "0" && cid != "0") {
        Serial.println("CREG OK: MCC=" + mcc + " MNC=" + mnc + 
                       " LAC=" + lac + " CID=" + cid);
        return true;
      }
    }
  }

  Serial.println("Toate metodele au esuat!");
  return false;
}


bool geolocalizeaza(String mcc, String mnc, String lac, String cid,
                    String &latOut, String &lonOut, String &precOut) {

  if (WiFi.status() != WL_CONNECTED) return false;
  afisare("LOCATIE", "Google API...", ST77XX_MAGENTA);

  int mccI = mcc.toInt();
  int mncI = mnc.toInt();
  int lacI = lac.toInt();
  int cidI = cid.toInt();

  String json = "{";
  json += "\"homeMobileCountryCode\":" + String(mccI) + ",";
  json += "\"homeMobileNetworkCode\":" + String(mncI) + ",";
  json += "\"radioType\":\"gsm\",";
  json += "\"considerIp\":false,";
  json += "\"cellTowers\":[{";
  json += "\"cellId\":"            + String(cidI) + ",";
  json += "\"locationAreaCode\":"  + String(lacI) + ",";
  json += "\"mobileCountryCode\":" + String(mccI) + ",";
  json += "\"mobileNetworkCode\":" + String(mncI);
  json += "}]}";

  Serial.println("JSON: " + json);

  WiFiClientSecure hc;
  hc.setInsecure();
  HTTPClient http;
  http.begin(hc, "https://www.googleapis.com/geolocation/v1/geolocate?key="
             + String(GOOGLE_API_KEY));
  http.addHeader("Content-Type", "application/json");

  int code = http.POST(json);
  Serial.println("HTTP: " + String(code));

  if (code != 200) {
    Serial.println("Eroare Google: " + http.getString());
    http.end();
    return false;
  }

  String body = http.getString();
  http.end();
  Serial.println("Google OK: " + body);

  DynamicJsonDocument doc(512);
  if (deserializeJson(doc, body)) return false;
  if (!doc.containsKey("location")) return false;

  double lat = doc["location"]["lat"];
  double lon = doc["location"]["lng"];
  double acc = doc["accuracy"];

  latOut  = String(lat, 6);
  lonOut  = String(lon, 6);
  precOut = String((int)acc);

  return true;
}

