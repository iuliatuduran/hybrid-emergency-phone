String getTimestamp() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return "??/??/???? ??:??";
  char buf[20];
  strftime(buf, sizeof(buf), "%d/%m/%Y %H:%M", &timeinfo);
  return String(buf);
}


